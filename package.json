{
  "name": "@nugehs/tieline",
  "version": "0.1.4",
  "mcpName": "io.github.nugehs/tieline",
  "description": "tieline — static frontend↔backend contract-drift checker. Pact without writing a single contract test.",
  "type": "module",
  "bin": {
    "tieline": "bin/tieline.mjs",
    "tieline-mcp": "bin/tieline-mcp.mjs"
  },
  "scripts": {
    "check": "node bin/tieline.mjs check",
    "mcp": "node bin/tieline-mcp.mjs",
    "test": "node --test test/*.test.mjs",
    "version": "node scripts/sync-server-version.mjs && git add server.json",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "contract-testing",
    "contract-drift",
    "openapi",
    "api-drift",
    "nestjs",
    "express",
    "fastapi",
    "spring",
    "rtk-query",
    "monorepo",
    "ci",
    "mcp",
    "model-context-protocol",
    "ai-agents"
  ],
  "author": "Segun Olumbe",
  "license": "MIT",
  "homepage": "https://github.com/nugehs/tieline#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nugehs/tieline.git"
  },
  "bugs": {
    "url": "https://github.com/nugehs/tieline/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
