{
  "openapi": "3.0.0",
  "info": { "title": "Express fixture mirror", "version": "1.0.0" },
  "servers": [{ "url": "http://localhost:3000" }],
  "paths": {
    "/health": { "get": { "operationId": "health" } },
    "/status": { "get": { "operationId": "statusGet" }, "post": { "operationId": "statusPost" } },
    "/api/v1/ping": { "get": { "operationId": "ping" } },
    "/api/v1/users": {
      "get": { "operationId": "listUsers" },
      "post": { "operationId": "createUser" }
    },
    "/api/v1/users/{id}": {
      "get": { "operationId": "getUser" },
      "delete": { "operationId": "deleteUser" }
    }
  }
}
